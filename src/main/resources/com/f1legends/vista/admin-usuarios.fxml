<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="app-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.f1legends.controller.Usuario.Admin.AdminUsuariosController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="18" styleClass="top-bar">
            <padding>
                <Insets top="18" right="28" bottom="18" left="28" />
            </padding>
            <ImageView fitWidth="82" preserveRatio="true">
                <image>
                    <Image url="@assets/logo-f1-legends.png" />
                </image>
            </ImageView>
            <VBox spacing="2">
                <Label text="Administración" styleClass="section-kicker" />
                <Label text="Usuarios" styleClass="screen-title" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Actualizar" onAction="#cargarUsuarios" styleClass="ghost-button" />
            <Button text="Volver" onAction="#volver" styleClass="secondary-small-button" />
        </HBox>
    </top>
    <center>
        <VBox spacing="16" styleClass="content-area">
            <padding>
                <Insets top="28" right="32" bottom="32" left="32" />
            </padding>
            <TableView fx:id="usuariosTable" styleClass="data-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="80" />
                    <TableColumn fx:id="usernameColumn" text="USERNAME" prefWidth="340" />
                    <TableColumn fx:id="rolColumn" text="ROL" prefWidth="220" />
                    <TableColumn fx:id="registroColumn" text="REGISTRO" prefWidth="220" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Button text="Eliminar seleccionado" onAction="#eliminarSeleccionado" styleClass="danger-button" />
                <Label fx:id="estadoLabel" styleClass="status-strip" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
            </HBox>
        </VBox>
    </center>
</BorderPane>
