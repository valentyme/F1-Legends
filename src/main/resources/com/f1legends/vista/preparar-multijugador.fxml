<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="app-root"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.f1legends.controller.PrepararMultijugadorController">

    <!-- ═══════════════════  TOP BAR  ═══════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="18" styleClass="top-bar">
            <padding>
                <Insets top="18" right="28" bottom="18" left="28" />
            </padding>
            <ImageView fitWidth="82" preserveRatio="true">
                <image>
                    <Image url="@assets/logo-f1-legends.png" />
                </image>
            </ImageView>
            <VBox spacing="2">
                <Label text="Carrera" styleClass="section-kicker" />
                <Label text="Multijugador Local" styleClass="screen-title" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Volver" onAction="#volver" styleClass="secondary-small-button" />
        </HBox>
    </top>

    <!-- ═══════════════════  CENTER  ═══════════════════ -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="edge-to-edge-scroll">
            <VBox spacing="18" styleClass="content-area">
                <padding>
                    <Insets top="28" right="32" bottom="32" left="32" />
                </padding>

                <!-- ──────────  JUGADOR PRINCIPAL  ────────── -->
                <VBox spacing="18" styleClass="wide-panel">
                    <Label text="Tu configuración" styleClass="content-title" />

                    <GridPane hgap="18" vgap="14">
                        <!-- Fila 0 – labels -->
                        <Label text="Piloto" styleClass="field-label"
                               GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <Label text="Reglamentación" styleClass="field-label"
                               GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <!-- Fila 1 – combos -->
                        <ComboBox fx:id="pilotoPrincipalCombo" maxWidth="Infinity" prefWidth="340"
                                  GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <ComboBox fx:id="reglamentacionCombo" maxWidth="Infinity" prefWidth="260"
                                  GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <!-- Fila 2 – labels -->
                        <Label text="Auto" styleClass="field-label"
                               GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <Label text="Estrategia de conducción" styleClass="field-label"
                               GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <!-- Fila 3 – combos -->
                        <ComboBox fx:id="autoPrincipalCombo" maxWidth="Infinity" prefWidth="340"
                                  GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <ComboBox fx:id="estrategiaCombo" maxWidth="Infinity"
                                  GridPane.columnIndex="1" GridPane.rowIndex="3" />

                        <!-- Fila 4 – labels -->
                        <Label text="Circuito" styleClass="field-label"
                               GridPane.columnIndex="0" GridPane.rowIndex="4" />
                        <Label text="Clima" styleClass="field-label"
                               GridPane.columnIndex="1" GridPane.rowIndex="4" />

                        <!-- Fila 5 – combos -->
                        <ComboBox fx:id="circuitoCombo" maxWidth="Infinity" prefWidth="340"
                                  GridPane.columnIndex="0" GridPane.rowIndex="5" />
                        <ComboBox fx:id="climaCombo" maxWidth="Infinity"
                                  GridPane.columnIndex="1" GridPane.rowIndex="5" />

                        <!-- Fila 6 – label vueltas -->
                        <Label text="Vueltas" styleClass="field-label"
                               GridPane.columnIndex="0" GridPane.rowIndex="6" />

                        <!-- Fila 7 – spinner vueltas -->
                        <Spinner fx:id="vueltasSpinner" editable="true" maxWidth="160"
                                 GridPane.columnIndex="0" GridPane.rowIndex="7" />
                    </GridPane>
                </VBox>

                <!-- ──────────  JUGADORES ADICIONALES  ────────── -->
                <VBox spacing="12" styleClass="wide-panel">
                    <Label text="Jugadores adicionales" styleClass="content-title" />

                    <Label text="Cada jugador necesita una cuenta registrada, un piloto y un auto de su escudería.
Si hay menos de 6 participantes en total, la grilla se completa con CPUs."
                           styleClass="field-label" wrapText="true" />

                    <!-- Encabezado de columnas -->
                    <HBox spacing="10">
                        <padding><Insets left="2" /></padding>
                        <Label text="Jugador (cuenta)" styleClass="field-label" prefWidth="200" />
                        <Label text="Piloto"           styleClass="field-label" prefWidth="230" />
                        <Label text="Auto"             styleClass="field-label" prefWidth="230" />
                    </HBox>

                    <!-- Filas dinámicas (se agregan por código) -->
                    <VBox fx:id="jugadoresAdicionalesBox" spacing="6" />

                    <!-- Botón agregar -->
                    <HBox>
                        <Button fx:id="agregarJugadorButton"
                                text="+ Agregar jugador"
                                onAction="#agregarJugador"
                                styleClass="secondary-small-button" />
                    </HBox>
                </VBox>

                <!-- ──────────  RESUMEN + ACCIÓN  ────────── -->
                <VBox spacing="10" styleClass="wide-panel">
                    <Label fx:id="resumenLabel" styleClass="status-strip" />
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Button text="Iniciar carrera" onAction="#iniciarCarrera" styleClass="primary-button" />
                        <Label fx:id="estadoLabel" styleClass="message-label" />
                    </HBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
