<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="app-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.f1legends.vista.JugadorHomeController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="18" styleClass="top-bar">
            <padding>
                <Insets top="18" right="28" bottom="18" left="28" />
            </padding>
            <ImageView fitWidth="92" preserveRatio="true">
                <image>
                    <Image url="@assets/logo-f1-legends.png" />
                </image>
            </ImageView>
            <VBox spacing="2">
                <Label text="Panel jugador" styleClass="section-kicker" />
                <Label fx:id="usuarioLabel" styleClass="screen-title" />
                <Label fx:id="detalleLabel" styleClass="muted-text" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Cerrar sesión" onAction="#cerrarSesion" styleClass="ghost-button" />
        </HBox>
    </top>
    <center>
        <VBox spacing="18" styleClass="content-area">
            <padding>
                <Insets top="28" right="32" bottom="32" left="32" />
            </padding>
            <Label text="¿Qué querés hacer ahora?" styleClass="content-title" />
            <GridPane hgap="16" vgap="16">
                <Button text="Jugar carrera" onAction="#abrirPrepararCarrera" styleClass="action-tile" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <Button text="Ranking global" onAction="#abrirRanking" styleClass="action-tile" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                <Button text="Modificar perfil" onAction="#abrirPerfil" styleClass="action-tile" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <Button text="Eliminar cuenta" onAction="#abrirPerfil" styleClass="action-tile danger-tile" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            </GridPane>
            <Label fx:id="estadoLabel" styleClass="status-strip" />
        </VBox>
    </center>
</BorderPane>
