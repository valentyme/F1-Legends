<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="app-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.f1legends.controller.PrepararCarreraController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="18" styleClass="top-bar">
            <padding>
                <Insets top="18" right="28" bottom="18" left="28" />
            </padding>
            <ImageView fitWidth="82" preserveRatio="true">
                <image>
                    <Image url="@assets/logo-f1-legends.png" />
                </image>
            </ImageView>
            <VBox spacing="2">
                <Label text="Carrera" styleClass="section-kicker" />
                <Label text="Preparar carrera" styleClass="screen-title" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Volver" onAction="#volver" styleClass="secondary-small-button" />
        </HBox>
    </top>
    <center>
        <VBox spacing="18" styleClass="content-area">
            <padding>
                <Insets top="28" right="32" bottom="32" left="32" />
            </padding>
            <VBox spacing="18" styleClass="wide-panel">
                <Label text="Configuración" styleClass="content-title" />
                <GridPane hgap="18" vgap="14">
                    <Label text="Piloto" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <ComboBox fx:id="pilotoCombo" maxWidth="Infinity" prefWidth="300" GridPane.columnIndex="0" GridPane.rowIndex="1" />

                    <Label text="Circuito" styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                    <ComboBox fx:id="circuitoCombo" maxWidth="Infinity" prefWidth="360" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <Label text="Reglamentación" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <ComboBox fx:id="reglamentacionCombo" maxWidth="Infinity" prefWidth="300" GridPane.columnIndex="0" GridPane.rowIndex="3" />

                    <Label text="Auto" styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    <ComboBox fx:id="autoCombo" maxWidth="Infinity" prefWidth="360" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                    <Label text="Estrategia" styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                    <ComboBox fx:id="estrategiaCombo" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                    <Label text="Clima" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                    <ComboBox fx:id="climaCombo" maxWidth="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="7" />

                    <Label text="Vueltas" styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                    <Spinner fx:id="vueltasSpinner" editable="true" maxWidth="160" GridPane.columnIndex="1" GridPane.rowIndex="7" />
                </GridPane>
                <Label fx:id="resumenLabel" styleClass="status-strip" />
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Button text="Iniciar carrera" onAction="#iniciarCarrera" styleClass="primary-button" />
                    <Label fx:id="estadoLabel" styleClass="message-label" />
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
